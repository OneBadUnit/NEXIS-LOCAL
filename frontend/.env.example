# ============================================================
# NEXIS Frontend — Environment Variables
# ============================================================
# Copy this file to .env (local dev) or set these in Vercel
# Project Settings → Environment Variables (production).
#
# NEVER commit .env to source control.
# .env is git-ignored. .env.example is safe to commit.
# ============================================================

# Supabase project URL (found in: Supabase → Project Settings → API)
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase public anon key (found in: Supabase → Project Settings → API)
# This key is safe to expose in the browser — it carries no elevated privileges.
# DO NOT use the service_role key here. The service_role key must NEVER appear
# in any frontend file.
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API base URL.
# For local development this is NOT required — the app defaults to http://localhost:8000
# automatically when running on localhost:3000 or 127.0.0.1:3000.
# Only set this when deploying the frontend to a hosted environment pointing at a remote backend.
# REACT_APP_API_BASE_URL=http://localhost:8000
